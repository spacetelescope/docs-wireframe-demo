{
  "name": "wireframe-review-action",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub Action to review wireframe demos against PR diffs using an LLM",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "minimatch": "^9.0.4",
    "yaml": "^2.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vercel/ncc": "^0.38.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
